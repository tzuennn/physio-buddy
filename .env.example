# Copy this file to .env and fill in your values.
# Lines that are commented out are optional — the app works without them.
# NEVER commit a .env file with real keys into git.

# ── LLM agentic coach ─────────────────────────────────────────────────────────
# Without this the app falls back to the rule-based adaptive coach automatically.
#
# RECOMMENDED (free, no credit card): Groq
#   1. Sign up at https://console.groq.com — takes 2 minutes
#   2. Create an API key
#   3. Paste it below
# LLM_API_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile
#
# Alternative – OpenAI (paid):
# LLM_API_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
#
# Alternative – Local Ollama (free, runs on your machine, no key needed):
# LLM_API_URL=http://localhost:11434/v1
# LLM_MODEL=llama3
#
# LLM_TIMEOUT_S=3.0

# ── MERaLiON audio strain analysis (optional) ─────────────────────────────────
# MERALION_API_KEY=your_key_here
# MERALION_BASE_URL=https://api.cr8lab.com
# MERALION_TIMEOUT_S=20

# ── MediaPipe model (optional overrides) ──────────────────────────────────────
MEDIAPIPE_POSE_TASK_AUTO_DOWNLOAD=true
MEDIAPIPE_POSE_TASK_CACHE_DIR=~/.cache/physio-buddy/models
# MEDIAPIPE_POSE_TASK_MODEL_PATH=/path/to/pose_landmarker_full.task
